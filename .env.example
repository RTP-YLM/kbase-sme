# =============================================================================
# KbaseSME — Environment Variables
# Copy เป็น .env แล้วใส่ค่าจริง | ห้าม commit .env ลง git
# =============================================================================

# =============================================================================
# DATABASE (PostgreSQL + pgvector)
# =============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/kbase
# Supabase (ใช้ service role เท่านั้น — ห้าม anon key ฝั่ง backend)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# =============================================================================
# REDIS (Queue + Semantic Cache)
# =============================================================================
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# JWT AUTH
# =============================================================================
JWT_SECRET=                          # openssl rand -hex 32
JWT_EXPIRE_HOURS=24
JWT_ALGORITHM=HS256

# =============================================================================
# SINGLE-TENANT CONFIG (DFY phase)
# =============================================================================
TENANT_ID=00000000-0000-0000-0000-000000000001

# =============================================================================
# LLM PROVIDER — ตั้งค่าเพียง provider เดียวต่อ instance
# =============================================================================

# Option A: Alibaba/Qwen (POC ปัจจุบัน)
LLM_PROVIDER=alibaba
ALIBABA_API_KEY=
ALIBABA_MODEL=qwen3.5-flash
ALIBABA_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Option B: OpenAI
# LLM_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1-nano

# Option C: Anthropic
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Option D: On-Prem Ollama (Typhoon 2)
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://ollama:11434/v1
# OLLAMA_MODEL=typhoon2

# =============================================================================
# EMBEDDING (BGE-M3 1024-dim)
# =============================================================================
BGE_MODEL_PATH=./models/bge-m3
BGE_DEVICE=cpu                       # 'cpu' | 'cuda' | 'mps'

# =============================================================================
# RERANKER (bge-reranker-v2-m3)
# =============================================================================
RERANKER_MODEL_PATH=./models/bge-reranker-v2-m3
NO_ANSWER_THRESHOLD=0.3
RERANK_TOP_N=5

# =============================================================================
# OCR (Typhoon Vision — E2-3)
# =============================================================================
# รับ API key ที่ https://opentyphoon.ai
TYPHOON_OCR_API_KEY=

# =============================================================================
# LINE OA
# =============================================================================
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# =============================================================================
# SEMANTIC CACHE
# =============================================================================
CACHE_SIMILARITY_THRESHOLD=0.92
CACHE_TTL_HOURS=24

# =============================================================================
# APP
# =============================================================================
APP_ENV=development                  # 'development' | 'production'
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO                       # ห้าม log ENV values ทุก level

# =============================================================================
# SECURITY
# =============================================================================
ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT_PER_MINUTE=10
